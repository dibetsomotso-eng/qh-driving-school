/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes security by default, restricting all data access unless explicitly allowed.
 * It is designed for prototyping, so data shape validation is minimal to enable rapid iteration.
 * All write operations require authentication and are generally limited to authenticated users.
 *
 * Data Structure:
 * The Firestore database contains the following top-level collections:
 * - /bookings: Stores booking submissions.
 * - /contactSubmissions: Stores contact form submissions.
 * - /subscribers: Stores newsletter subscriptions.
 * - /testimonials: Stores student testimonials.
 * - /blogPosts: Stores blog posts.
 *
 * Key Security Decisions:
 * - Unauthenticated access is disallowed for all write operations.
 * - List operation will be blocked unless otherwised specified.
 *
 * Denormalization for Authorization:
 *  N/A - Simple collections with no concept of ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to create a booking.
     * @path /bookings/{bookingId}
     * @allow (create) - Any unauthenticated user can create a booking.
     * @deny (create) - No denial condition
     * @principle Allows unauthenticated users to submit bookings.
     */
    match /bookings/{bookingId} {
      allow get: if false;
      allow list: if false;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to create a contact submission.
     * @path /contactSubmissions/{contactId}
     * @allow (create) - Any unauthenticated user can create a contact submission.
     * @deny (create) - No denial condition
     * @principle Allows unauthenticated users to submit contact forms.
     */
    match /contactSubmissions/{contactId} {
      allow get: if false;
      allow list: if false;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to create a subscriber.
     * @path /subscribers/{subscriberId}
     * @allow (create) - Any unauthenticated user can create a subscriber.
     * @deny (create) - No denial condition
     * @principle Allows unauthenticated users to subscribe to the newsletter.
     */
    match /subscribers/{subscriberId} {
      allow get: if false;
      allow list: if false;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to create a testimonial.
     * @path /testimonials/{testimonialId}
     * @allow (create) - Any unauthenticated user can create a testimonial.
     * @deny (create) - No denial condition
     * @principle Allows unauthenticated users to submit testimonials.
     */
    match /testimonials/{testimonialId} {
      allow get: if false;
      allow list: if false;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to create a blog post.
     * @path /blogPosts/{postId}
     * @allow (create) - Any unauthenticated user can create a blog post.
     * @deny (create) - No denial condition
     * @principle Allows unauthenticated users to submit blog posts.
     */
    match /blogPosts/{postId} {
      allow get: if false;
      allow list: if false;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }
  }
}