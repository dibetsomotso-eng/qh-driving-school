/**
 * @file Firebase Security Rules for Driving School App
 *
 * @core_philosophy This ruleset prioritizes secure access to user-submitted
 * data like bookings and contact forms. It defaults to only allowing
 * authenticated users to create data and protects against unauthorized
 * modification or deletion. Public read access is granted for certain
 * collections like blog posts and testimonials to allow open access to
 * marketing content.
 *
 * @data_structure The Firestore database is structured with top-level collections
 * for each major entity: bookings, contactSubmissions, subscribers,
 * testimonials, and blogPosts.
 *
 * @key_security_decisions
 *   - Bookings, Contact Submissions, and Subscribers require authentication to create.
 *   - No listing is generally allowed for sensitive collections.
 *   - Blog posts and testimonials are publicly readable.
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to create a booking.
     * @path /bookings/{bookingId}
     * @allow (create) Any authenticated user can create a booking.
     * @deny (read, update, delete) No one can read, update, or delete bookings.
     * @principle Allows public booking submissions.
     */
    match /bookings/{bookingId} {
      allow create: if isSignedIn();
      allow get, list, update, delete: if false;
    }

    /**
     * @description Allows anyone to create a contact submission.
     * @path /contactSubmissions/{contactId}
     * @allow (create) Any authenticated user can create a contact submission.
     * @deny (read, update, delete) No one can read, update, or delete contact submissions.
     * @principle Allows public contact form submissions.
     */
    match /contactSubmissions/{contactId} {
      allow create: if isSignedIn();
      allow get, list, update, delete: if false;
    }

    /**
     * @description Allows anyone to create a subscriber.
     * @path /subscribers/{subscriberId}
     * @allow (create) Any authenticated user can create a subscriber.
     * @deny (read, update, delete) No one can read, update, or delete subscribers.
     * @principle Allows public newsletter subscriptions.
     */
    match /subscribers/{subscriberId} {
      allow create: if isSignedIn();
      allow get, list, update, delete: if false;
    }

    /**
     * @description Allows public read access to testimonials and authenticated write access.
     * @path /testimonials/{testimonialId}
     * @allow (get, list) Any user can read testimonials.
     * @allow (create) Only an authenticated user can create a testimonial.
     * @deny (update, delete) No one can update or delete testimonials.
     * @principle Allows public viewing of testimonials with restricted write access.
     */
    match /testimonials/{testimonialId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    /**
     * @description Allows public read access to blog posts and authenticated write access.
     * @path /blogPosts/{postId}
     * @allow (get, list) Any user can read blog posts.
     * @allow (create) Only an authenticated user can create a blog post.
     * @deny (update, delete) No one can update or delete blog posts.
     * @principle Allows public viewing of blog posts with restricted write access.
     */
    match /blogPosts/{postId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ---- Helper functions ----

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }
  }
}