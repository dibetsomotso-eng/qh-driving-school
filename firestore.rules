/**
 * @file Firestore Security Rules
 * @description This ruleset defines access control for the driving school application.
 *
 * Core Philosophy:
 *  This ruleset enforces a public read, restricted write model, where all users can read data,
 *  but only authenticated users can create, update, or delete it. No ownership checks are implemented
 *  at this stage.
 *
 * Data Structure:
 *  The Firestore database consists of top-level collections for bookings, contact submissions,
 *  subscribers, testimonials, and blog posts. Each collection stores documents representing
 *  the respective entities. There are no user-specific subcollections at this point.
 *
 * Key Security Decisions:
 *  - Public Read: All read operations (get, list) are allowed for all collections.
 *  - Authenticated Writes: All write operations (create, update, delete) require the user to be signed in.
 *  - No Data Validation: Data validation is not enforced in this prototyping phase.
 *
 *  These rules prioritize rapid development by allowing any authenticated user to perform write operations.
 *  In a production environment, more fine-grained access control (e.g., role-based access) would be necessary.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read bookings, but only authenticated users to create, update, or delete them.
     * @path /bookings/{bookingId}
     * @allow (get, list): if true
     * @allow (create): if isSignedIn()
     * @allow (update): if isSignedIn()
     * @allow (delete): if isSignedIn()
     * @deny (create): if !isSignedIn()
     * @deny (update): if !isSignedIn()
     * @deny (delete): if !isSignedIn()
     * @principle Public read, authenticated writes.
     */
    match /bookings/{bookingId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows anyone to read contact submissions, but only authenticated users to create, update, or delete them.
     * @path /contactSubmissions/{contactId}
     * @allow (get, list): if true
     * @allow (create): if isSignedIn()
     * @allow (update): if isSignedIn()
     * @allow (delete): if isSignedIn()
     * @deny (create): if !isSignedIn()
     * @deny (update): if !isSignedIn()
     * @deny (delete): if !isSignedIn()
     * @principle Public read, authenticated writes.
     */
    match /contactSubmissions/{contactId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows anyone to read subscribers, but only authenticated users to create, update, or delete them.
     * @path /subscribers/{subscriberId}
     * @allow (get, list): if true
     * @allow (create): if isSignedIn()
     * @allow (update): if isSignedIn()
     * @allow (delete): if isSignedIn()
     * @deny (create): if !isSignedIn()
     * @deny (update): if !isSignedIn()
     * @deny (delete): if !isSignedIn()
     * @principle Public read, authenticated writes.
     */
    match /subscribers/{subscriberId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows anyone to read testimonials, but only authenticated users to create, update, or delete them.
     * @path /testimonials/{testimonialId}
     * @allow (get, list): if true
     * @allow (create): if isSignedIn()
     * @allow (update): if isSignedIn()
     * @allow (delete): if isSignedIn()
     * @deny (create): if !isSignedIn()
     * @deny (update): if !isSignedIn()
     * @deny (delete): if !isSignedIn()
     * @principle Public read, authenticated writes.
     */
    match /testimonials/{testimonialId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

     /**
      * @description Allows anyone to read blog posts, but only authenticated users to create, update, or delete them.
      * @path /blogPosts/{postId}
      * @allow (get, list): if true
      * @allow (create): if isSignedIn()
      * @allow (update): if isSignedIn()
      * @allow (delete): if isSignedIn()
      * @deny (create): if !isSignedIn()
      * @deny (update): if !isSignedIn()
      * @deny (delete): if !isSignedIn()
      * @principle Public read, authenticated writes.
      */
    match /blogPosts/{postId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }

  // Helper function to determine if the user is signed in
  function isSignedIn() {
    return request.auth != null;
  }
}