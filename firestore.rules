/**
 * @file Firestore Security Rules for QH Driving School.
 *
 * @core_philosophy This ruleset allows public read and write access to the bookings, testimonials,
 * and subscribers collections. No authentication is required for any operation.
 *
 * @data_structure Data is stored in three top-level collections: /bookings, /testimonials, and /subscribers.
 *
 * @key_security_decisions All collections are publicly readable and writable. This is suitable for
 * capturing data from public forms.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read and write access to the bookings collection.
     * @path /bookings/{bookingId}
     * @allow (create) Any unauthenticated user can create a booking.
     * @allow (get, list) Any unauthenticated user can read a booking.
     * @deny (update, delete) No one can update or delete a booking.
     * @principle Allows unauthenticated users to submit booking requests.
     */
    match /bookings/{bookingId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    /**
     * @description Allows public read and write access to the testimonials collection.
     * @path /testimonials/{testimonialId}
     * @allow (create) Any unauthenticated user can create a testimonial.
     * @allow (get, list) Any unauthenticated user can read a testimonial.
     * @deny (update, delete) No one can update or delete a testimonial.
     * @principle Allows unauthenticated users to submit testimonials.
     */
    match /testimonials/{testimonialId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    /**
     * @description Allows public read and write access to the subscribers collection.
     * @path /subscribers/{subscriberId}
     * @allow (create) Any unauthenticated user can create a subscriber.
     * @allow (get, list) Any unauthenticated user can read a subscriber.
     * @deny (update, delete) No one can update or delete a subscriber.
     * @principle Allows unauthenticated users to subscribe to the newsletter.
     */
    match /subscribers/{subscriberId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if false;
    }
  }
}