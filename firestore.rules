/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes rapid prototyping by focusing on authorization and deferring data validation. It uses a public-read, owner-write model for most collections, allowing flexible data shapes for faster iteration.
 *
 * Data Structure:
 * The Firestore database contains several top-level collections: bookings, contact submissions, subscribers, testimonials and blog posts. Each collection stores data related to its specific purpose.
 *
 * Key Security Decisions:
 * - Public Read Access: All collections are publicly readable to facilitate easy data display.
 * - Owner-Only Writes: Write access (create, update, delete) is restricted to authenticated users, based on the presence of an 'ownerId' field within the document that must match the authenticated user's UID.
 * - Missing Owner Field: If a schema lacks a clearly defined ownerId, writes are disabled with a placeholder comment to highlight the problem.
 * - No User Listing: Listing users is disallowed.
 *
 * Denormalization for Authorization:
 *  To avoid `get()` calls in rules, the owner is identified by an `ownerId` field in each document. This field must match the authenticated user's `uid` for write operations.
 *
 * Structural Segregation:
 *  The application uses top-level collections for both private and public data. The public data is readable by all, while write access is restricted to the owner.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read bookings, but only authenticated users to create, update, or delete them.
     * @path /bookings/{bookingId}
     * @allow (get, list): if true
     * @allow (create): if request.auth != null
     * @allow (update): if request.auth != null && resource.data.ownerId == request.auth.uid && resource != null
     * @allow (delete): if request.auth != null && resource.data.ownerId == request.auth.uid && resource != null
     * @deny (create): if request.auth == null
     * @deny (update): if request.auth == null || resource.data.ownerId != request.auth.uid || resource == null
     * @deny (delete): if request.auth == null || resource.data.ownerId != request.auth.uid || resource == null
     * @principle Allows public reads, restricts writes to authenticated owners.
     */
    match /bookings/{bookingId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Allows anyone to read contact submissions, but only authenticated users to create, update, or delete them.
     * @path /contactSubmissions/{contactId}
     * @allow (get, list): if true
     * @allow (create): if request.auth != null
     * @allow (update): if request.auth != null && resource.data.ownerId == request.auth.uid && resource != null
     * @allow (delete): if request.auth != null && resource.data.ownerId == request.auth.uid && resource != null
     * @deny (create): if request.auth == null
     * @deny (update): if request.auth == null || resource.data.ownerId != request.auth.uid || resource == null
     * @deny (delete): if request.auth == null || resource.data.ownerId != request.auth.uid || resource == null
     * @principle Allows public reads, restricts writes to authenticated owners.
     */
    match /contactSubmissions/{contactId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Allows anyone to read subscribers, but only authenticated users to create, update, or delete them.
     * @path /subscribers/{subscriberId}
     * @allow (get, list): if true
     * @allow (create): if request.auth != null
     * @allow (update): if request.auth != null && resource.data.ownerId == request.auth.uid && resource != null
     * @allow (delete): if request.auth != null && resource.data.ownerId == request.auth.uid && resource != null
     * @deny (create): if request.auth == null
     * @deny (update): if request.auth == null || resource.data.ownerId != request.auth.uid || resource == null
     * @deny (delete): if request.auth == null || resource.data.ownerId != request.auth.uid || resource == null
     * @principle Allows public reads, restricts writes to authenticated owners.
     */
    match /subscribers/{subscriberId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Allows anyone to read testimonials, but only authenticated users to create, update, or delete them.
     * @path /testimonials/{testimonialId}
     * @allow (get, list): if true
     * @allow (create): if request.auth != null
     * @allow (update): if request.auth != null && resource.data.ownerId == request.auth.uid && resource != null
     * @allow (delete): if request.auth != null && resource.data.ownerId == request.auth.uid && resource != null
     * @deny (create): if request.auth == null
     * @deny (update): if request.auth == null || resource.data.ownerId != request.auth.uid || resource == null
     * @deny (delete): if request.auth == null || resource.data.ownerId != request.auth.uid || resource == null
     * @principle Allows public reads, restricts writes to authenticated owners.
     */
    match /testimonials/{testimonialId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid && resource != null;
    }

   /**
     * @description Allows anyone to read blog posts, but only authenticated users to create, update, or delete them.
     * @path /blogPosts/{postId}
     * @allow (get, list): if true
     * @allow (create): if request.auth != null
     * @allow (update): if request.auth != null && resource.data.ownerId == request.auth.uid && resource != null
     * @allow (delete): if request.auth != null && resource.data.ownerId == request.auth.uid && resource != null
     * @deny (create): if request.auth == null
     * @deny (update): if request.auth == null || resource.data.ownerId != request.auth.uid || resource == null
     * @deny (delete): if request.auth == null || resource.data.ownerId != request.auth.uid || resource == null
     * @principle Allows public reads, restricts writes to authenticated owners.
     */
    match /blogPosts/{postId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid && resource != null;
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}