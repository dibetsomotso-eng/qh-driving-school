/**
 * @description This ruleset enforces a role-based access control model for managing blog posts, testimonials, bookings, contact submissions and subscribers.
 * Only authenticated users with admin role can create, update, or delete blog posts and testimonials.
 * Bookings, contact submissions, and subscribers are publicly writable but not readable by any user.
 * @dataStructure
 * - /bookings/{bookingId}: Stores booking submissions made through the website.
 * - /contactSubmissions/{contactId}: Stores contact form submissions from the website.
 * - /subscribers/{subscriberId}: Stores newsletter subscription data.
 * - /testimonials/{testimonialId}: Stores testimonial submissions from students.
 * - /blogPosts/{postId}: Stores the blog posts for the website.
 * @keySecurityDecisions
 * - Public write, no read access for Bookings, ContactSubmissions and Subscribers.
 * - Only admins can manage blog posts and testimonials.
 * - No listing of any collections is allowed to prevent data leakage.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to create booking documents, but denies all read access.
     * @path /bookings/{bookingId}
     * @allow (create) Any unauthenticated user can create a booking.
     * @deny (get, list, update, delete) No one can read, update, or delete a booking.
     * @principle Public write, no read access.
     */
    match /bookings/{bookingId} {
      allow get: if false;
      allow list: if false;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to create contact submission documents, but denies all read access.
     * @path /contactSubmissions/{contactId}
     * @allow (create) Any unauthenticated user can create a contact submission.
     * @deny (get, list, update, delete) No one can read, update, or delete a contact submission.
     * @principle Public write, no read access.
     */
    match /contactSubmissions/{contactId} {
      allow get: if false;
      allow list: if false;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to create subscriber documents, but denies all read access.
     * @path /subscribers/{subscriberId}
     * @allow (create) Any unauthenticated user can create a subscriber.
     * @deny (get, list, update, delete) No one can read, update, or delete a subscriber.
     * @principle Public write, no read access.
     */
    match /subscribers/{subscriberId} {
      allow get: if false;
      allow list: if false;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows only authenticated admins to manage testimonial documents.
     * @path /testimonials/{testimonialId}
     * @allow (create, update, delete) Only authenticated admins can manage testimonials.
     * @deny (get, list) No one can read or list testimonials.
     * @deny (create, update, delete) Non-admin users cannot manage testimonials.
     * @principle Role-based access control.
     */
    match /testimonials/{testimonialId} {
      allow get: if false;
      allow list: if false;
      allow create: if isAdmin();
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Allows only authenticated admins to manage blog post documents.
     * @path /blogPosts/{postId}
     * @allow (create, update, delete) Only authenticated admins can manage blog posts.
     * @deny (get, list) No one can read or list blog posts.
     * @deny (create, update, delete) Non-admin users cannot manage blog posts.
     * @principle Role-based access control.
     */
    match /blogPosts/{postId} {
      allow get: if false;
      allow list: if false;
      allow create: if isAdmin();
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
        return isSignedIn() && request.auth.token.admin == true;
    }
  }
}