# ─── InsForge ──────────────────────────────────────────────────────────────────
# Get these from your InsForge project dashboard.

# NEXT_PUBLIC_ prefix = safe to expose to the browser (public read-only data only)
NEXT_PUBLIC_INSFORGE_URL=https://your-project-id.region.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your-anon-jwt-here

# Server-only admin key — NEVER prefix with NEXT_PUBLIC_
INSFORGE_API_KEY=ik_your_api_key_here

# ─── Sanity CMS ────────────────────────────────────────────────────────────────
# Project ID and dataset are safe to expose (they are already public in Sanity).
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Write token — server-only, never prefix with NEXT_PUBLIC_
SANITY_API_TOKEN=your-sanity-write-token-here

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Server-only — never prefix with NEXT_PUBLIC_
RESEND_API_KEY=re_your_resend_api_key_here

# Comma-separated list of admin email addresses that receive booking/contact alerts.
# Server-only — never prefix with NEXT_PUBLIC_
ADMIN_EMAILS=admin@yourdomain.com

# The "from" address used in outbound emails. Must be a verified Resend domain.
# Defaults to onboarding@resend.dev if omitted (Resend sandbox only).
FROM_EMAIL=noreply@yourdomain.com

# Your business name used in email templates.
BUSINESS_NAME=QH Driving School

# ─── AI (Google Genkit / Gemini) ───────────────────────────────────────────────
# Server-only key used by @genkit-ai/google-genai — never prefix with NEXT_PUBLIC_
GOOGLE_GENAI_API_KEY=your-google-ai-studio-api-key-here

# ─── Google Reviews (Places API) ───────────────────────────────────────────────
# Server-only — API key is used only in API routes, not the browser.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
GOOGLE_PLACE_ID=your-google-place-id-here

# ─── Key Rotation Reminder ─────────────────────────────────────────────────────
# If any key above has been committed to git or otherwise exposed, rotate it
# immediately in the respective service dashboard before redeploying.
# Rotation checklist:
#   InsForge:   Dashboard → Settings → API Keys
#   Sanity:     manage.sanity.io → Settings → API tokens
#   Resend:     resend.com → API Keys
#   Google AI:  aistudio.google.com → API Keys
#   Google Maps: console.cloud.google.com → Credentials
